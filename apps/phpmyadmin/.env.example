# Image pinning (recommended)
PMA_IMAGE_TAG=5

# Fixed server mode (recommended)
PMA_HOST=db-vm-01.your.lan
PMA_PORT=3306

# Reverse-proxy path (only if you publish through a proxy with a subpath)
# Example: https://tools.example.net/pma/
# PMA_ABSOLUTE_URI=https://tools.example.net/pma/   # optional [3](http://underpop.online.fr/p/phpmyadmin/help/docker-environment-variables.htm)[4](http://underpop.online.fr/p/phpmyadmin/help/installing-using-docker.htm)

# Arbitrary server selection (leave disabled unless you really need it)
PMA_ARBITRARY=0