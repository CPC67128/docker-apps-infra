# ----- Image pinning -----
# Prefer pinning to an LTS tag for stability (example: lts, 11.4, 11.8, etc.)
MARIADB_IMAGE_TAG=lts

# ----- Required root password (choose ONE approach) -----
# Option A (simple): set root password directly
MARIADB_ROOT_PASSWORD=CHANGEME_STRONG

# Option B (safer): use Docker secret / file variant (uncomment when you use secrets)
# MARIADB_ROOT_PASSWORD_FILE=/run/secrets/mariadb_root_password

# ----- Optional initialization (applies only on first init when datadir is empty) -----
MARIADB_DATABASE=appdb
MARIADB_USER=appuser
MARIADB_PASSWORD=CHANGEME_APPUSER

# Optional: restrict where root can connect from
# Setting to localhost restricts root access to local socket use
# MARIADB_ROOT_HOST=localhost