# -----------------------------
# MariaDB connection
# -----------------------------
# If MariaDB is in the same compose project/network, use the service name.
MYSQL_HOST=mariadb
MYSQL_PORT=3306
MYSQL_USER=backup
MYSQL_PASS=change_me

# Optional: leave empty to dump ALL databases (default --all-databases) [2](https://hub.docker.com/r/fradelg/mysql-cron-backup/tags)
MYSQL_DATABASE=mydatabase

# -----------------------------
# Schedule / retention
# -----------------------------
# Cron format. Default behavior uses UTC timezone in this image. [2](https://hub.docker.com/r/fradelg/mysql-cron-backup/tags)
# Example: daily at 02:00 UTC
CRON_TIME=0 2 * * *

# Keep the latest N backups (no limit if unset) [2](https://hub.docker.com/r/fradelg/mysql-cron-backup/tags)
MAX_BACKUPS=14

# -----------------------------
# Lifecycle behavior (1 = enabled)
# -----------------------------
INIT_BACKUP=1
EXIT_BACKUP=
INIT_RESTORE_LATEST=

# -----------------------------
# mysqldump tuning (optional)
# -----------------------------
# Passed directly to mysqldump [2](https://hub.docker.com/r/fradelg/mysql-cron-backup/tags)
MYSQLDUMP_OPTS=--single-transaction --quick --routines --events --triggers

# -----------------------------
# TLS/SSL (optional)
# -----------------------------
# Passed as mysql client SSL options [2](https://hub.docker.com/r/fradelg/mysql-cron-backup/tags)
MYSQL_SSL_OPTS=